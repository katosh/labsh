#!/bin/bash --
# labsh — Project-local JupyterLab launcher, kernel manager, and notebook
# runner.  (Run `labsh help` for full usage.)

set -eo pipefail

PROG="labsh"
LAB_PYTHON="3.12"                         # Python used by uvx for JupyterLab
DIR="$PWD"
: "${JUPYTER_CONFIG_DIR:=$DIR/.jupyter}"
: "${JUPYTER_DATA_DIR:=$DIR/.jupyter/share/jupyter}"
KERNELS_DIR="$JUPYTER_DATA_DIR/kernels"
VENV_DIR="$DIR/.venv"                      # project venv (kernels only)
LAB_LOCK_FILE="$JUPYTER_CONFIG_DIR/.labshvenv.lock"  # pinned deps for labsh helper venv
BG_PID_FILE="$JUPYTER_CONFIG_DIR/labsh.bg.pid"
BG_LOG_FILE="$JUPYTER_CONFIG_DIR/labsh.bg.log"
TOKEN_FILE="$JUPYTER_CONFIG_DIR/token"        # stable Jupyter auth token (0600)

# --- NFS performance: redirect uv cache and venvs to local storage --------
# /fh/fast/ is NFS (Isilon) with ~20ms per metadata op.  Python venv startup
# touches hundreds of files, so keeping caches and venvs on /tmp cuts startup
# from seconds to milliseconds.  The trade-off: /tmp is ephemeral (cleared on
# reboot or sandbox restart).  Persistent state stays on NFS; hot paths don't.
: "${UV_CACHE_DIR:=/tmp/uv-cache-$(id -u)}"
: "${UV_LINK_MODE:=copy}"                   # avoids hardlink failures across fs
export UV_CACHE_DIR UV_LINK_MODE

# Labsh helper venv lives on /tmp for speed, with a symlink from .jupyter/.labshvenv
# so the rest of the script has a stable path.  If /tmp is unavailable, falls
# back to NFS.
_LAB_VENV_TMP="/tmp/labsh-venv-$(id -u)-$(echo "$DIR" | md5sum | cut -c1-8)"
LAB_VENV_LINK="$JUPYTER_CONFIG_DIR/.labshvenv"

# Resolve the actual labsh venv path: follow symlink if it exists and target
# is alive; otherwise we'll create a new one in ensure_lab_venv.
if [ -L "$LAB_VENV_LINK" ] && [ -x "$(readlink -f "$LAB_VENV_LINK" 2>/dev/null)/bin/python" ]; then
    LAB_VENV_DIR="$(readlink -f "$LAB_VENV_LINK")"
else
    LAB_VENV_DIR="$_LAB_VENV_TMP"
fi

# Absolute path to the directory holding this script — so the Python helper
# (bin/_labsh_kernel.py) can be located even when the user runs `labsh` via a
# symlink or from $PATH.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HELPER_PY="$SCRIPT_DIR/_labsh_kernel.py"
# VERSION lives alongside the script in installed layout (lib/labsh/bin/),
# or one directory up in the source tree.
if [ -f "$SCRIPT_DIR/../VERSION" ]; then
    VERSION_FILE="$SCRIPT_DIR/../VERSION"
else
    VERSION_FILE="$SCRIPT_DIR/VERSION"
fi

export JUPYTER_CONFIG_DIR JUPYTER_DATA_DIR

SSL_DIR="$JUPYTER_CONFIG_DIR/ssl"

err() { echo "$PROG: $*" >&2; }
die() { err "$@"; exit 1; }

ensure_jupyter_config() {
    # Write jupyter_server_config.py if it doesn't exist.  Handles:
    # - SQLite3 missing: disable notebook trust signature DB to avoid
    #   "Missing SQLite3, all notebooks will be untrusted!" warnings.
    #   Not security-critical for single-user HPC setups.
    local cfg="$JUPYTER_CONFIG_DIR/jupyter_server_config.py"
    [ -f "$cfg" ] && return 0
    mkdir -p "$JUPYTER_CONFIG_DIR"
    cat > "$cfg" <<'PYCFG'
# Auto-generated by labsh — safe to edit.
# Disable notebook trust signature DB if SQLite3 is unavailable.
# Not security-critical for single-user sandboxed setups.
try:
    import sqlite3  # noqa: F401
except ImportError:
    import warnings
    warnings.warn("labsh: SQLite3 unavailable, disabling notebook trust signatures")
    c.NotebookNotary.db_file = ":memory:"  # noqa: F821
PYCFG
}

usage() {
    cat <<'HELP'
labsh — Project-local JupyterLab launcher, kernel manager, and notebook runner.

Runs JupyterLab from the current directory with all configuration and
kernels under ./.jupyter, so each project gets its own reproducible Jupyter
setup with no writes to ~/.local. Also provides CLI access to running
kernels so code can be executed against a live notebook's state without
clicking through the web UI.

USAGE
  labsh                          Start JupyterLab in the current directory
                               (foreground; typical when run in a tmux pane)
  labsh start [--https] [--port N] [--ip ADDR] [--with-ai]
                               Start JupyterLab in the background, log to
                               ./.jupyter/labsh.bg.log, return immediately
  labsh stop                     Stop a background JupyterLab owning this project
  labsh status                   List running labsh servers and kernels
  labsh url                      Print the access URL of the running server
  labsh password                 Set a persistent password (stored in ./.jupyter)
  labsh token [--rotate|--path]  Print / rotate / locate the stable auth token
  labsh help                     Show this help
  labsh version                  Print version and exit

  labsh kernel add [NAME] [PKGS...]
                               Create ./.venv, register it as a kernelspec,
                               and install PKGS (e.g. pandas numpy)
  labsh kernel register --project DIR [--name N] [--notebook PATH]
                               Register an EXISTING venv (DIR/.venv) as a
                               kernelspec under this labsh project; bakes
                               $LD_LIBRARY_PATH into kernel.json for
                               Lmod-built pythons. With --notebook, also
                               pins notebook metadata + attaches.
  labsh kernel install PKGS...   Install packages into the kernel .venv
  labsh kernel shell             Enter a subshell with .venv activated
  labsh kernel run [--] CMD...   Run a command inside the .venv
  labsh kernel list              List registered kernelspecs in this project
  labsh kernel remove NAME       Unregister a kernelspec

  labsh kernel ps                List RUNNING kernels (PID, short id, notebook)
  labsh kernel find QUERY        Show running kernel(s) matching a notebook path
  labsh kernel exec [-n NB|-k K] CODE
                               Run CODE in a live kernel; state persists.
                               `-` or `-f FILE` reads from stdin/file.
  labsh kernel inspect [-n NB|-k K] [PATTERN]
                               `whos`-style listing of live variables
  labsh kernel interrupt [-n NB|-k K]
                               Interrupt a running kernel
  labsh kernel restart [-n NB|-k K]
                               Restart a kernel (server-managed only)

  labsh notebook attach [PATH]   Ensure a kernel is running for PATH (spawns
                               a session via the labsh server if needed)
  labsh notebook cells [-n PATH] List cells
  labsh notebook show  [-n PATH] IDX
  labsh notebook append  [-n PATH] [--markdown] [--execute] CODE
  labsh notebook replace [-n PATH] IDX           [--execute] CODE

TWO RUN MODES
  1. Agent background mode
       labsh start                      # agent daemonizes the server
       labsh notebook attach foo.ipynb  # spawns a kernel
       labsh kernel exec -n foo.ipynb "df = pd.read_csv('data.csv')"
       labsh kernel exec -n foo.ipynb "df.shape"

  2. User foreground mode (tmux pane inside the sandbox)
       labsh                            # bare `labsh` runs in foreground
     Then in another pane, the agent uses the same `labsh kernel exec -n ...`
     commands to attach to whatever notebook you have open in the browser.

SELECTORS
  `-n NOTEBOOK` resolves to a running kernel by matching the kernel's
  jupyter_session against: absolute path, PWD-relative path, basename
  (globbed under PWD), or substring. On ambiguous matches the command
  prints the candidates and exits non-zero — by design, it will not guess.

  `-k SELECTOR` accepts PID, short kernel id (first 8 hex), or full
  connection file path.

  With neither flag and exactly one running kernel, that kernel is used.

NATIVE SERVER INTERFACE
  Runtime kernel commands (ps, find, exec, inspect, interrupt, restart,
  notebook attach/append/replace) interface with a running Jupyter server
  natively: REST for discovery and session management, the kernel
  websocket (/api/kernels/<id>/channels) for execution. Servers are
  discovered from ./.jupyter runtime files, parent directories' .jupyter
  trees (a workspace-wide server whose root contains this project), and
  the standard jupyter runtime dir. Kernels without a serving session
  fall back to the direct connection-file/ZMQ path automatically.

    --server URL    target one specific server (env: LABSH_SERVER);
                    token via --token, LABSH_TOKEN, or ?token= in the URL
    --local         force the connection-file/ZMQ path (skip the server)

NETWORK & AUTH
  Default bind is 0.0.0.0 — reachable from other machines on the local
  network. Override with `--ip 127.0.0.1` (or `IP=127.0.0.1`) to restrict
  to localhost only.

  A stable auth token is generated on first start and stored at
  ./.jupyter/token (mode 0600). It persists across restarts, so agents on
  the same machine can read the file and authenticate without coordination.
  `labsh token` prints it; `labsh token --rotate` regenerates it. The
  token is passed to Jupyter via JUPYTER_TOKEN so it never appears in
  `ps` output.

  Optional password layer: `labsh password` sets a browser-friendly
  password. Password and token coexist — clients may use either.

  TRANSPORT SECURITY: plain HTTP on a public bind sends the token in
  cleartext. Strongly recommended whenever binding off localhost:
    labsh start --https           # auto-generates cert in .jupyter/ssl/
    labsh --https --port 9012     # foreground, custom port, HTTPS

  `--port N` picks port N (auto-increments if taken, up to 10 tries).
  `--ip ADDR` overrides the bind address.

  Use `labsh url` to retrieve the full URL+token of the running server.

NFS PERFORMANCE
  On shared HPC (NFS/Lustre), Python venv startup is ~46x slower than on
  local storage.  labsh mitigates this automatically:
    - UV_CACHE_DIR defaults to /tmp/uv-cache-$UID (not ~/.cache/uv)
    - UV_LINK_MODE defaults to 'copy' (avoids cross-fs hardlink failures)
    - Labsh helper venv lives on /tmp with a symlink from .jupyter/.labshvenv
    - Package installs are followed by `compileall` to pre-generate .pyc
  The /tmp venvs are ephemeral (lost on reboot).  `labsh kernel add` or
  `labsh start` recreates them automatically when needed.

AI EXTENSION (notebook-intelligence)
  Off by default. The package pulls `tiktoken`, which only ships
  manylinux_2_28 wheels — on hosts with glibc < 2.28 (Ubuntu 18.04,
  RHEL 7) the source build needs Rust 1.85+ and routinely fails. To
  enable when the host can install it cleanly:

    labsh start --with-ai          # one-off
    LABSH_AI=1 labsh start         # via env (e.g. exported in ~/.bashrc)

  `--no-ai` overrides `LABSH_AI=1` from the CLI.

ENVIRONMENT VARIABLES
  PORT, IP                     Defaults for --port / --ip
  JUPYTER_CERTFILE/KEYFILE     TLS cert / key (enables HTTPS if both set)
  JUPYTER_CONFIG_DIR           default: ./.jupyter
  JUPYTER_DATA_DIR             default: ./.jupyter/share/jupyter
  LABSH_AI                     1/true → enable notebook-intelligence
  LABSH_SERVER                 Default --server URL for runtime kernel cmds
  LABSH_TOKEN                  Default --token for LABSH_SERVER
  UV_CACHE_DIR                 default: /tmp/uv-cache-$UID
  UV_LINK_MODE                 default: copy

REQUIREMENTS
  `uv` on PATH (used by labsh to manage the project venv and run jupyter-lab).
    curl -LsSf https://astral.sh/uv/install.sh | sh
  See https://docs.astral.sh/uv/ for details.

FURTHER READING
  For the full workflow reference — kernel discovery internals,
  attach/exec/append recipes, ambiguity handling, and troubleshooting —
  see doc/labsh.md in the source tree, or:
    https://github.com/katosh/labsh
HELP
}

require_uv() {
    if ! command -v uv >/dev/null 2>&1; then
        die "uv not found on PATH. Install it (no root needed) with one of:
  curl -LsSf https://astral.sh/uv/install.sh | sh
  brew install uv
See https://docs.astral.sh/uv/ for details, or run \`$PROG help\`."
    fi
}

sanitize_kernel_name() {
    # Lowercase; collapse runs of non-[a-z0-9._-] into '-'; trim leading/trailing '-'.
    printf '%s' "$1" | tr '[:upper:]' '[:lower:]' \
        | sed -e 's/[^a-z0-9._-]\+/-/g' -e 's/^-\+//' -e 's/-\+$//'
}

is_lmod_python() {
    # Lmod-managed pythons (and their library trees) live under
    # /app/software/. Without LD_LIBRARY_PATH baked into kernel.json, the
    # kernel's dynamic loader can't find libpython*.so.* and the kernel
    # dies with "Kernel died before replying to kernel_info".
    local py="$1" real
    real="$(readlink -f "$py" 2>/dev/null)" || return 1
    case "$real" in
        /app/software/*) return 0 ;;
        *) return 1 ;;
    esac
}

resolve_kernel_ld_library_path() {
    # Echo the LD_LIBRARY_PATH to bake into kernel.json (or empty).
    # Args: <python-path> [<override-set 0|1> <override-value>]
    # Behavior:
    #   override-set=1: use override-value verbatim (empty string clears).
    #   else, if python is Lmod-managed: require $LD_LIBRARY_PATH set, bake it.
    #   else: empty (don't bake).
    local py="$1" override_set="${2:-0}" override="${3-}"
    if [ "$override_set" = "1" ]; then
        printf '%s' "$override"
        return 0
    fi
    if is_lmod_python "$py"; then
        if [ -z "${LD_LIBRARY_PATH:-}" ]; then
            die "venv python at $py is from /app/software/ (Lmod) but \$LD_LIBRARY_PATH is empty — \`module load\` the matching Python module (or pass --ld-library-path PATHS) so the kernel can find libpython*.so at startup"
        fi
        printf '%s' "$LD_LIBRARY_PATH"
        return 0
    fi
    printf ''
}

patch_kernel_json_ld() {
    # Add env.LD_LIBRARY_PATH to a kernel.json. No-op if value is empty.
    local spec="$1" ld="$2"
    [ -n "$ld" ] || return 0
    [ -f "$spec" ] || die "cannot patch kernel.json: $spec missing"
    LABSH_LD="$ld" python3 - "$spec" <<'PYEOF'
import json, os, sys
p = sys.argv[1]
with open(p) as fh:
    d = json.load(fh)
d.setdefault("env", {})["LD_LIBRARY_PATH"] = os.environ["LABSH_LD"]
with open(p, "w") as fh:
    json.dump(d, fh, indent=2)
    fh.write("\n")
PYEOF
}

pin_notebook_kernel() {
    # Pin metadata.kernelspec.name to NAME in NB; create a fresh empty
    # nbformat-v4 notebook if missing.
    local nb="$1" name="$2" display="$3"
    LABSH_NB="$nb" LABSH_NAME="$name" LABSH_DISPLAY="$display" python3 - <<'PYEOF'
import json, os
nb_path = os.environ["LABSH_NB"]
name = os.environ["LABSH_NAME"]
display = os.environ["LABSH_DISPLAY"]
if os.path.isfile(nb_path):
    with open(nb_path) as fh:
        nb = json.load(fh)
else:
    parent = os.path.dirname(nb_path)
    if parent:
        os.makedirs(parent, exist_ok=True)
    nb = {"cells": [], "metadata": {}, "nbformat": 4, "nbformat_minor": 5}
nb.setdefault("metadata", {})["kernelspec"] = {
    "display_name": display, "language": "python", "name": name,
}
with open(nb_path, "w") as fh:
    json.dump(nb, fh, indent=1)
    fh.write("\n")
PYEOF
}

ensure_venv_with_ipykernel() {
    # Create .venv if needed, ensure ipykernel+ipywidgets, install extra
    # packages passed as arguments.
    require_uv
    if [ ! -x "$VENV_DIR/bin/python" ]; then
        echo "$PROG: creating venv at $VENV_DIR" >&2
        uv venv "$VENV_DIR"
    fi
    local missing=()
    "$VENV_DIR/bin/python" -c "import ipykernel_launcher" 2>/dev/null || missing+=(ipykernel)
    "$VENV_DIR/bin/python" -c "import ipywidgets"        2>/dev/null || missing+=(ipywidgets)
    # Append any extra packages requested by the caller
    if [ $# -gt 0 ]; then
        missing+=("$@")
    fi
    if [ ${#missing[@]} -gt 0 ]; then
        echo "$PROG: installing ${missing[*]} into $VENV_DIR" >&2
        uv pip install --python "$VENV_DIR/bin/python" "${missing[@]}"
        # Pre-compile .pyc to cut NFS round-trips on subsequent imports
        echo "$PROG: pre-compiling .pyc files..." >&2
        "$VENV_DIR/bin/python" -m compileall -q \
            "$VENV_DIR/lib" 2>/dev/null || true
        # Snapshot kernel deps so the venv can be reproduced
        local kernel_lock="$JUPYTER_CONFIG_DIR/.kernel-deps.lock"
        mkdir -p "$JUPYTER_CONFIG_DIR"
        uv pip freeze --python "$VENV_DIR/bin/python" \
            > "$kernel_lock" 2>/dev/null || true
        echo "$PROG: pinned kernel deps to $kernel_lock" >&2
    fi
}

ensure_lab_venv() {
    # Ensure labsh's own helper venv exists with psutil, jupyter_client,
    # nbformat, websocket-client.  This is separate from the project .venv — labsh never
    # installs packages into the project's venv (only `labsh kernel add`
    # touches .venv).
    #
    # The venv lives on /tmp for NFS performance (Python startup is 46x
    # faster on tmpfs).  A symlink from .jupyter/.labshvenv points to the
    # tmpfs location so all paths stay stable.
    #
    # A lockfile (.jupyter/.labshvenv.lock) on persistent NFS captures exact
    # package versions after first install.  On rebuild (after /tmp wipe),
    # packages are restored from the lockfile for reproducibility.
    require_uv
    LAB_VENV_DIR="$_LAB_VENV_TMP"
    local created_fresh=0
    if [ ! -x "$LAB_VENV_DIR/bin/python" ]; then
        echo "$PROG: creating labsh helper venv at $LAB_VENV_DIR (tmpfs)" >&2
        uv venv "$LAB_VENV_DIR"
        created_fresh=1
    fi
    # Maintain the symlink from project dir
    mkdir -p "$JUPYTER_CONFIG_DIR"
    if [ ! -L "$LAB_VENV_LINK" ] || [ "$(readlink -f "$LAB_VENV_LINK" 2>/dev/null)" != "$(readlink -f "$LAB_VENV_DIR")" ]; then
        ln -sfn "$LAB_VENV_DIR" "$LAB_VENV_LINK"
    fi

    local missing=()
    "$LAB_VENV_DIR/bin/python" -c "import psutil"         2>/dev/null || missing+=(psutil)
    "$LAB_VENV_DIR/bin/python" -c "import jupyter_client"  2>/dev/null || missing+=(jupyter_client)
    "$LAB_VENV_DIR/bin/python" -c "import nbformat"        2>/dev/null || missing+=(nbformat)
    "$LAB_VENV_DIR/bin/python" -c "import websocket"       2>/dev/null || missing+=(websocket-client)
    if [ ${#missing[@]} -gt 0 ]; then
        if [ "$created_fresh" -eq 1 ] && [ -f "$LAB_LOCK_FILE" ]; then
            # Rebuild from lockfile for reproducibility
            echo "$PROG: restoring labsh helper venv from $LAB_LOCK_FILE" >&2
            uv pip install --python "$LAB_VENV_DIR/bin/python" \
                -r "$LAB_LOCK_FILE"
        else
            echo "$PROG: installing ${missing[*]} into labsh helper venv" >&2
            uv pip install --python "$LAB_VENV_DIR/bin/python" "${missing[@]}"
            # Freeze exact versions to lockfile on persistent storage
            uv pip freeze --python "$LAB_VENV_DIR/bin/python" \
                > "$LAB_LOCK_FILE" 2>/dev/null || true
        fi
        # Pre-compile .pyc to halve NFS round-trips on subsequent imports
        "$LAB_VENV_DIR/bin/python" -m compileall -q \
            "$LAB_VENV_DIR/lib" 2>/dev/null || true
    fi
}

check_lab_venv() {
    # Fast check: labsh helper venv and all deps already installed?
    # Returns 0 if ready, 1 if not.  Does NOT install anything.
    # Follows the symlink at .jupyter/.labshvenv -> /tmp/labsh-venv-...
    local venv="$LAB_VENV_DIR"
    if [ -L "$LAB_VENV_LINK" ]; then
        venv="$(readlink -f "$LAB_VENV_LINK" 2>/dev/null)" || return 1
        LAB_VENV_DIR="$venv"  # update for subsequent run_helper_fast
    fi
    [ -x "$venv/bin/python" ] || return 1
    "$venv/bin/python" -c "import psutil, jupyter_client, nbformat, websocket" 2>/dev/null
}

run_helper() {
    ensure_lab_venv
    [ -f "$HELPER_PY" ] || die "cannot find helper at $HELPER_PY"
    exec "$LAB_VENV_DIR/bin/python" "$HELPER_PY" "$@"
}

# Like run_helper but fails fast if labsh helper venv isn't ready.
# Used by read-only/query commands that should never install anything.
run_helper_fast() {
    if ! check_lab_venv; then
        die "labsh helper venv not ready. Run 'labsh start' or 'labsh kernel add' first."
    fi
    [ -f "$HELPER_PY" ] || die "cannot find helper at $HELPER_PY"
    exec "$LAB_VENV_DIR/bin/python" "$HELPER_PY" "$@"
}

# Check for an already-running labsh server by scanning jpserver-*.json files
# in the runtime directory. Returns 0 (true) if a live server is found and
# prints its URL to stderr; returns 1 (false) otherwise.
check_existing_server() {
    local runtime_dir="$JUPYTER_DATA_DIR/runtime"
    [ -d "$runtime_dir" ] || return 1
    local jf pid url
    for jf in "$runtime_dir"/jpserver-*.json; do
        [ -e "$jf" ] || continue
        pid="$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('pid',''))" "$jf" 2>/dev/null)" || continue
        [ -n "$pid" ] || continue
        if kill -0 "$pid" 2>/dev/null; then
            url="$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('url',''))" "$jf" 2>/dev/null)" || url="(unknown)"
            echo "$PROG: server is already running (pid $pid, $url)" >&2
            echo "$PROG: use 'labsh status' to see details, or 'labsh stop' to shut it down." >&2
            return 0
        fi
    done
    return 1
}

cmd_kernel_add() {
    # Usage: labsh kernel add [NAME] [PACKAGES...]
    # NAME defaults to basename of $PWD.  Any remaining args are extra
    # packages to install alongside ipykernel (e.g. pandas numpy).
    local raw_name="${1:-$(basename "$DIR")}"
    shift 2>/dev/null || true
    local name; name="$(sanitize_kernel_name "$raw_name")"
    [ -n "$name" ] || die "kernel add: empty name after sanitization"
    ensure_venv_with_ipykernel "$@"  # pass extra packages through
    ensure_lab_venv                  # ensure labsh helper venv exists too
    mkdir -p "$JUPYTER_CONFIG_DIR"
    local ld
    ld="$(resolve_kernel_ld_library_path "$VENV_DIR/bin/python")"
    "$VENV_DIR/bin/python" -m ipykernel install \
        --prefix "$JUPYTER_CONFIG_DIR" \
        --name "$name" \
        --display-name "$name (.venv)"
    local spec="$KERNELS_DIR/$name/kernel.json"
    patch_kernel_json_ld "$spec" "$ld"
    echo "$PROG: registered kernel '$name' → $KERNELS_DIR/$name" >&2
    if [ -n "$ld" ]; then
        echo "$PROG: kernel.json env.LD_LIBRARY_PATH baked in (Lmod-managed python)" >&2
    fi
}

cmd_kernel_register() {
    # Usage: labsh kernel register --project DIR [--name NAME]
    #                              [--display-name DISP]
    #                              [--ld-library-path PATHS]
    #                              [--notebook PATH] [--no-attach]
    #
    # Register an EXISTING venv (DIR/.venv) as a kernelspec under the
    # current labsh project. Bakes $LD_LIBRARY_PATH into kernel.json
    # for Lmod-managed pythons so the kernel can find libpython*.so at
    # startup. With --notebook, also pins metadata.kernelspec.name and
    # calls `notebook attach` (unless --no-attach).
    local project="" raw_name="" display=""
    local ld_override="" ld_override_set=0
    local notebook="" no_attach=0
    while [ $# -gt 0 ]; do
        case "$1" in
            --project)        [ -n "${2:-}" ] || die "kernel register: --project requires a value"
                              project="$2"; shift 2 ;;
            --project=*)      project="${1#--project=}"; shift ;;
            --name)           [ -n "${2:-}" ] || die "kernel register: --name requires a value"
                              raw_name="$2"; shift 2 ;;
            --name=*)         raw_name="${1#--name=}"; shift ;;
            --display-name)   [ -n "${2:-}" ] || die "kernel register: --display-name requires a value"
                              display="$2"; shift 2 ;;
            --display-name=*) display="${1#--display-name=}"; shift ;;
            --ld-library-path)
                              ld_override_set=1; ld_override="${2-}"; shift 2 ;;
            --ld-library-path=*)
                              ld_override_set=1; ld_override="${1#--ld-library-path=}"; shift ;;
            --notebook)       [ -n "${2:-}" ] || die "kernel register: --notebook requires a value"
                              notebook="$2"; shift 2 ;;
            --notebook=*)     notebook="${1#--notebook=}"; shift ;;
            --no-attach)      no_attach=1; shift ;;
            -h|--help)        cat <<'KRHELP'
labsh kernel register — register an existing project venv as a kernelspec.

USAGE
  labsh kernel register --project DIR [--name NAME] [--display-name DISP]
                        [--ld-library-path PATHS] [--notebook PATH]
                        [--no-attach]

Run from a labsh project root (where you invoked `labsh start`,
containing .jupyter/). The kernelspec is written under
.jupyter/share/jupyter/kernels/<NAME>/, and `kernel.json` gets an
`env` block with $LD_LIBRARY_PATH baked in so kernels built against an
Lmod-managed Python (realpath under /app/software/) don't die at
startup with "Kernel died before replying to kernel_info".

OPTIONS
  --project DIR             Directory containing .venv/ (required)
  --name NAME               Kernelspec name (default: basename of DIR)
  --display-name DISP       Display name (default: "Python (NAME)")
  --ld-library-path PATHS   Override LD_LIBRARY_PATH baked into kernel.json
                            (default: $LD_LIBRARY_PATH if the venv's python
                            is from /app/software/, else unset). Pass
                            an empty string to skip baking entirely.
  --notebook PATH           Pin metadata.kernelspec.name to NAME in PATH
                            (creates a fresh notebook if missing). Then
                            calls `labsh notebook attach PATH --kernel-name
                            NAME` unless --no-attach.
  --no-attach               Skip the final `labsh notebook attach` call.
KRHELP
                              return 0 ;;
            *) die "kernel register: unknown arg '$1' (try '$PROG kernel register --help')" ;;
        esac
    done
    [ -n "$project" ] || die "kernel register: --project DIR is required (try '$PROG kernel register --help')"
    local project_abs
    project_abs="$(cd "$project" 2>/dev/null && pwd)" \
        || die "kernel register: --project '$project' is not a directory"
    local py="$project_abs/.venv/bin/python"
    [ -x "$py" ] || die "kernel register: no venv at $project_abs/.venv (expected $py)"

    local name
    name="$(sanitize_kernel_name "${raw_name:-$(basename "$project_abs")}")"
    [ -n "$name" ] || die "kernel register: empty name after sanitization"
    [ -n "$display" ] || display="Python ($name)"

    local ld
    ld="$(resolve_kernel_ld_library_path "$py" "$ld_override_set" "$ld_override")"

    # Ensure ipykernel is importable in the venv. The check + install run
    # with the resolved LD_LIBRARY_PATH so subprocess Python can start at
    # all on Lmod hosts.
    if ! LD_LIBRARY_PATH="${ld:-${LD_LIBRARY_PATH:-}}" \
            "$py" -c "import ipykernel" >/dev/null 2>&1; then
        require_uv
        echo "$PROG: installing ipykernel into $project_abs/.venv" >&2
        LD_LIBRARY_PATH="${ld:-${LD_LIBRARY_PATH:-}}" \
            uv pip install --python "$py" --quiet ipykernel \
            || die "kernel register: ipykernel install failed"
    fi

    mkdir -p "$JUPYTER_CONFIG_DIR"
    LD_LIBRARY_PATH="${ld:-${LD_LIBRARY_PATH:-}}" \
        "$py" -m ipykernel install \
            --prefix "$JUPYTER_CONFIG_DIR" \
            --name "$name" \
            --display-name "$display" \
        || die "kernel register: ipykernel install failed"

    local spec="$KERNELS_DIR/$name/kernel.json"
    [ -f "$spec" ] || die "kernel register: ipykernel install reported success but $spec is missing"
    patch_kernel_json_ld "$spec" "$ld"
    echo "$PROG: registered kernel '$name' → $KERNELS_DIR/$name" >&2
    [ -n "$ld" ] && echo "$PROG: kernel.json env.LD_LIBRARY_PATH baked in" >&2

    if [ -n "$notebook" ]; then
        local nb_abs="$notebook"
        case "$nb_abs" in /*) ;; *) nb_abs="$DIR/$notebook" ;; esac
        pin_notebook_kernel "$nb_abs" "$name" "$display"
        echo "$PROG: pinned $nb_abs → kernelspec '$name'" >&2
        if [ "$no_attach" -ne 1 ]; then
            run_helper_fast notebook attach "$nb_abs" --kernel-name "$name"
            # run_helper_fast execs; never returns
        fi
    fi
    echo "$PROG: done. Use:" >&2
    echo "  labsh notebook attach <NB> --kernel-name $name" >&2
    echo "  labsh kernel exec -n <NB> 'import sys; print(sys.executable)'" >&2
}

cmd_kernel_list() {
    if [ ! -d "$KERNELS_DIR" ]; then
        echo "$PROG: no project-local kernels (no $KERNELS_DIR)" >&2
        return 0
    fi
    local found=0
    for k in "$KERNELS_DIR"/*/; do
        [ -d "$k" ] || continue
        found=1
        printf '  %s\n' "$(basename "$k")"
    done
    if [ "$found" -eq 0 ]; then
        echo "$PROG: no project-local kernels in $KERNELS_DIR" >&2
    fi
}

cmd_kernel_remove() {
    local raw_name="${1:?usage: labsh kernel remove NAME}"
    local name; name="$(sanitize_kernel_name "$raw_name")"
    local target="$KERNELS_DIR/$name"
    [ -d "$target" ] || die "kernel remove: '$name' not found at $target"
    rm -rf "$target"
    echo "$PROG: removed kernel '$name'" >&2
}

cmd_kernel_install() {
    # Usage: labsh kernel install PACKAGES...
    # Install packages into the project .venv.  The venv must already exist
    # (run `labsh kernel add` first).
    [ $# -gt 0 ] || die "kernel install: no packages specified
Usage: labsh kernel install PACKAGES..."
    require_uv
    [ -x "$VENV_DIR/bin/python" ] || die "kernel install: no .venv found. Run '$PROG kernel add' first."
    echo "$PROG: installing $* into $VENV_DIR" >&2
    uv pip install --python "$VENV_DIR/bin/python" "$@"
    # Pre-compile and update lockfile
    "$VENV_DIR/bin/python" -m compileall -q "$VENV_DIR/lib" 2>/dev/null || true
    local kernel_lock="$JUPYTER_CONFIG_DIR/.kernel-deps.lock"
    mkdir -p "$JUPYTER_CONFIG_DIR"
    uv pip freeze --python "$VENV_DIR/bin/python" > "$kernel_lock" 2>/dev/null || true
    echo "$PROG: updated $kernel_lock" >&2
}

cmd_kernel_shell() {
    # Usage: labsh kernel shell
    # Drop into a subshell with the project .venv activated.
    [ -x "$VENV_DIR/bin/python" ] || die "kernel shell: no .venv found. Run '$PROG kernel add' first."
    echo "$PROG: entering .venv shell (exit to return)" >&2
    # Use VIRTUAL_ENV + prepend to PATH so the shell behaves like
    # `source .venv/bin/activate` without modifying the user's rc files.
    VIRTUAL_ENV="$VENV_DIR" \
    PATH="$VENV_DIR/bin:$PATH" \
        exec "${SHELL:-/bin/bash}"
}

cmd_kernel_run() {
    # Usage: labsh kernel run [--] CMD [ARGS...]
    # Run a command with the project .venv's python on PATH.
    [ -x "$VENV_DIR/bin/python" ] || die "kernel run: no .venv found. Run '$PROG kernel add' first."
    # Skip optional -- separator
    [ "${1:-}" = "--" ] && shift
    [ $# -gt 0 ] || die "kernel run: no command specified
Usage: labsh kernel run [--] CMD [ARGS...]"
    VIRTUAL_ENV="$VENV_DIR" \
    PATH="$VENV_DIR/bin:$PATH" \
        exec "$@"
}

cmd_kernel() {
    local sub="${1:-}"
    [ $# -gt 0 ] && shift
    case "$sub" in
        add)         cmd_kernel_add        "$@" ;;
        register|reg) cmd_kernel_register  "$@" ;;
        install|pip) cmd_kernel_install    "$@" ;;
        shell|sh)    cmd_kernel_shell      "$@" ;;
        run)         cmd_kernel_run        "$@" ;;
        list|ls)     cmd_kernel_list       "$@" ;;
        remove|rm)   cmd_kernel_remove     "$@" ;;
        ps|find|exec|inspect|interrupt|restart)
            run_helper_fast kernel "$sub" "$@" ;;
        ""|help|-h|--help)
            cat >&2 <<'KHELP'
Usage:
  labsh kernel add [NAME] [PKGS...]  Create ./.venv, register kernelspec, install packages
  labsh kernel register --project DIR [--name N] [--notebook PATH] [--no-attach]
                                     Register an EXISTING venv (DIR/.venv) as a kernelspec;
                                     bakes $LD_LIBRARY_PATH into kernel.json for Lmod pythons.
  labsh kernel install PKGS...       Install packages into the kernel .venv
  labsh kernel shell                 Enter a subshell with .venv activated
  labsh kernel run [--] CMD...       Run a command inside the .venv
  labsh kernel list                  List registered kernelspecs
  labsh kernel remove NAME           Unregister a kernelspec
  labsh kernel ps                    List RUNNING kernels (PID, id, notebook)
  labsh kernel find QUERY            Resolve a notebook path to its running kernel(s)
  labsh kernel exec [-n NB|-k K] CODE   Execute code in a running kernel
  labsh kernel inspect [-n NB|-k K]     Print live variables (%whos)
  labsh kernel interrupt [-n NB|-k K]   Interrupt a running kernel
  labsh kernel restart [-n NB|-k K]     Restart a kernel (server-managed only)

Runtime commands accept --server URL / --token TOK (env: LABSH_SERVER,
LABSH_TOKEN) to target a specific jupyter server, and --local to force
the direct connection-file/ZMQ path.
KHELP
            ;;
        *) die "kernel: unknown subcommand '$sub' (try '$PROG help')" ;;
    esac
}

cmd_notebook() {
    local sub="${1:-}"
    case "$sub" in
        # Read-only notebook commands: fast path
        cells|show|attach)
            run_helper_fast notebook "$@" ;;
        # Mutating commands may need full deps
        *)
            run_helper notebook "$@" ;;
    esac
}

ensure_ssl_cert() {
    # Generate a self-signed cert under .jupyter/ssl/ if none exists.
    # Returns 0 and sets JUPYTER_CERTFILE / JUPYTER_KEYFILE.
    if [ -n "${JUPYTER_CERTFILE:-}" ] && [ -n "${JUPYTER_KEYFILE:-}" ]; then
        [ -f "$JUPYTER_CERTFILE" ] || die "JUPYTER_CERTFILE not found: $JUPYTER_CERTFILE"
        [ -f "$JUPYTER_KEYFILE" ]  || die "JUPYTER_KEYFILE not found: $JUPYTER_KEYFILE"
        return 0
    fi
    mkdir -p "$SSL_DIR"
    JUPYTER_CERTFILE="$SSL_DIR/labsh.pem"
    JUPYTER_KEYFILE="$SSL_DIR/labsh.key"
    if [ -f "$JUPYTER_CERTFILE" ] && [ -f "$JUPYTER_KEYFILE" ]; then
        echo "$PROG: reusing existing cert at $SSL_DIR/" >&2
        return 0
    fi
    echo "$PROG: generating self-signed certificate in $SSL_DIR/" >&2
    openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
        -keyout "$JUPYTER_KEYFILE" -out "$JUPYTER_CERTFILE" \
        -subj "/CN=$(hostname)/O=labsh-self-signed" 2>/dev/null \
        || die "failed to generate self-signed certificate (is openssl installed?)"
    chmod 600 "$JUPYTER_KEYFILE"
    export JUPYTER_CERTFILE JUPYTER_KEYFILE
}

find_available_port() {
    # Find an available port starting from $1, trying up to 10 consecutive ports.
    # Prints the first available port. Returns 1 if none found.
    local port="${1:-8888}"
    local attempts=0
    while [ "$attempts" -lt 10 ]; do
        if ! python3 -c "
import socket, sys
s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
try:
    s.bind(('127.0.0.1', int(sys.argv[1])))
    s.close()
    sys.exit(0)
except OSError:
    s.close()
    sys.exit(1)
" "$port" 2>/dev/null; then
            port=$((port + 1))
            attempts=$((attempts + 1))
        else
            echo "$port"
            return 0
        fi
    done
    return 1
}

ensure_token() {
    # Ensure a stable Jupyter auth token exists at $TOKEN_FILE (mode 0600).
    # Generated once per project; same value every start so agents on the
    # machine can read the file and authenticate without coordination.
    mkdir -p "$JUPYTER_CONFIG_DIR"
    if [ ! -s "$TOKEN_FILE" ]; then
        local tok
        tok="$(python3 -c 'import secrets; print(secrets.token_hex(24))' 2>/dev/null)" \
            || tok="$(openssl rand -hex 24 2>/dev/null)" \
            || die "failed to generate auth token (need python3 or openssl)"
        (umask 077 && printf '%s\n' "$tok" > "$TOKEN_FILE")
    fi
    chmod 600 "$TOKEN_FILE" 2>/dev/null || true
    # Defense in depth: if this .jupyter dir has no gitignore, drop one that
    # covers secrets. Users can still commit config.py etc. explicitly.
    local gi="$JUPYTER_CONFIG_DIR/.gitignore"
    if [ ! -e "$gi" ]; then
        cat > "$gi" <<'GI'
# Auto-generated by labsh — do not commit secrets or runtime state.
token
labsh.bg.pid
labsh.bg.log
runtime/
share/jupyter/runtime/
ssl/
jupyter_server_config.json
GI
    fi
}

read_token() {
    # Print the current token, generating one if absent.
    ensure_token
    # Strip trailing newline(s) for safe use in env vars / URLs.
    tr -d '\r\n' < "$TOKEN_FILE"
}

check_password_set() {
    # Check if a Jupyter password is configured. Returns 0 if set.
    # Jupyter Server 2.x writes IdentityProvider.hashed_password; older
    # versions used ServerApp.password / NotebookApp.password. Users may
    # also hand-configure in jupyter_server_config.py.
    local json_file="$JUPYTER_CONFIG_DIR/jupyter_server_config.json"
    local py_file="$JUPYTER_CONFIG_DIR/jupyter_server_config.py"
    if [ -f "$json_file" ] && python3 -c "
import json, sys
d = json.load(open(sys.argv[1]))
def get(section, key):
    return d.get(section, {}).get(key) or ''
if (get('IdentityProvider', 'hashed_password')
        or get('PasswordIdentityProvider', 'hashed_password')
        or get('ServerApp', 'password')
        or get('NotebookApp', 'password')):
    sys.exit(0)
sys.exit(1)
" "$json_file" 2>/dev/null; then
        return 0
    fi
    if [ -f "$py_file" ] && grep -Eq \
        '^[[:space:]]*c\.(IdentityProvider|PasswordIdentityProvider)\.hashed_password[[:space:]]*=[[:space:]]*["'"'"'][^"'"'"']+["'"'"']|^[[:space:]]*c\.(ServerApp|NotebookApp)\.password[[:space:]]*=[[:space:]]*["'"'"'][^"'"'"']+["'"'"']' \
        "$py_file"; then
        return 0
    fi
    return 1
}

# Parse --https, --port, --with-ai, and pass-through args for start/serve.
# Sets: USE_HTTPS, RESOLVED_PORT, RESOLVED_IP, TLS_ARGS, PASSTHROUGH_ARGS,
#       WITH_AI, WITH_ARGS.
parse_server_flags() {
    USE_HTTPS=0
    RESOLVED_PORT="${PORT:-8888}"
    # Default bind: 0.0.0.0. Most users are on institute-internal networks
    # and want browser access from other machines. Override with
    # `--ip 127.0.0.1` or `IP=127.0.0.1 labsh start` for localhost-only.
    RESOLVED_IP="${IP:-0.0.0.0}"
    TLS_ARGS=()
    PASSTHROUGH_ARGS=()

    # AI extension (notebook-intelligence) is opt-in. It pulls tiktoken,
    # which only ships manylinux_2_28 wheels — on glibc 2.27 hosts the
    # source build needs Rust 1.85+ and routinely fails. Default off so
    # `labsh start` works out of the box; opt in via `--with-ai` or
    # `LABSH_AI=1`. `--no-ai` overrides the env var on the CLI.
    WITH_AI=0
    case "${LABSH_AI:-}" in
        1|true|TRUE|yes|YES|on|ON) WITH_AI=1 ;;
    esac

    while [ $# -gt 0 ]; do
        case "$1" in
            --https)
                USE_HTTPS=1
                shift ;;
            --with-ai)
                WITH_AI=1
                shift ;;
            --no-ai)
                WITH_AI=0
                shift ;;
            --port)
                [ -n "${2:-}" ] || die "start: --port requires a value"
                RESOLVED_PORT="$2"
                shift 2 ;;
            --port=*)
                RESOLVED_PORT="${1#--port=}"
                shift ;;
            --ip)
                [ -n "${2:-}" ] || die "start: --ip requires a value"
                RESOLVED_IP="$2"
                shift 2 ;;
            --ip=*)
                RESOLVED_IP="${1#--ip=}"
                shift ;;
            *)
                PASSTHROUGH_ARGS+=("$1")
                shift ;;
        esac
    done

    WITH_ARGS=(
        --with jupyterlmod
        --with jupyterlab_notify
        --with jupyterlab_execute_time
        --with jupyter-resource-usage
        --with jupyterlab-widgets
    )
    if [ "$WITH_AI" -eq 1 ]; then
        WITH_ARGS+=(--with notebook-intelligence)
    fi

    if [ "$USE_HTTPS" -eq 1 ]; then
        ensure_ssl_cert
        TLS_ARGS=(--certfile "$JUPYTER_CERTFILE" --keyfile "$JUPYTER_KEYFILE")
    elif [ -n "${JUPYTER_CERTFILE:-}" ] && [ -n "${JUPYTER_KEYFILE:-}" ]; then
        TLS_ARGS=(--certfile "$JUPYTER_CERTFILE" --keyfile "$JUPYTER_KEYFILE")
        USE_HTTPS=1
    fi

    # Loud warning when binding publicly over plain HTTP: the auth token
    # travels in cleartext on every request. Fine inside a trusted network
    # (campus VPN, single-tenant VPC) but a real risk elsewhere.
    if [ "$USE_HTTPS" -eq 0 ] && [ "$RESOLVED_IP" != "127.0.0.1" ]; then
        echo "$PROG: WARNING: binding to $RESOLVED_IP over plain HTTP." >&2
        echo "$PROG: the auth token will travel in cleartext on every request." >&2
        echo "$PROG: strongly recommend 'labsh start --https' for encrypted transport." >&2
    fi

    # Auto-find available port
    local avail
    avail="$(find_available_port "$RESOLVED_PORT")" \
        || die "no available port found in range $RESOLVED_PORT-$((RESOLVED_PORT + 9))"
    if [ "$avail" != "$RESOLVED_PORT" ]; then
        echo "$PROG: port $RESOLVED_PORT in use, using $avail" >&2
    fi
    RESOLVED_PORT="$avail"
}

cmd_start() {
    require_uv
    mkdir -p "$JUPYTER_CONFIG_DIR" "$JUPYTER_DATA_DIR"

    # Refuse if any labsh server is already running for this project
    # (catches both `labsh` foreground and `labsh start` background).
    if check_existing_server; then
        return 1
    fi

    parse_server_flags "$@"
    ensure_lab_venv
    ensure_jupyter_config
    # Stable token — passed via env (not argv) so it never lands in /proc/PID/cmdline
    # or `ps` output on multi-user machines.
    JUPYTER_TOKEN="$(read_token)"
    export JUPYTER_TOKEN

    uvx --python "$LAB_PYTHON" --from jupyterlab \
        "${WITH_ARGS[@]}" \
        jupyter-lab \
        --port "$RESOLVED_PORT" \
        --ip "$RESOLVED_IP" \
        --no-browser \
        ${TLS_ARGS[@]+"${TLS_ARGS[@]}"} \
        ${PASSTHROUGH_ARGS[@]+"${PASSTHROUGH_ARGS[@]}"} \
        > "$BG_LOG_FILE" 2>&1 &
    local bg_pid=$!
    echo "$bg_pid" > "$BG_PID_FILE"

    # Wait for the server URL to appear in the log, then print it cleanly.
    local url_line auth_info
    local _attempt
    for _attempt in $(seq 1 30); do
        if grep -qE 'https?://' "$BG_LOG_FILE" 2>/dev/null; then
            url_line="$(grep -oE 'https?://[^ ]+' "$BG_LOG_FILE" | tail -1)" || true
            if [ -n "$url_line" ]; then
                # Determine auth status: token is always on; password is optional.
                if check_password_set; then
                    auth_info="token + password"
                else
                    auth_info="token"
                fi
                echo "$PROG: running at $url_line ($auth_info)" >&2
                echo "$PROG: token at $TOKEN_FILE" >&2
                echo "$PROG: log at $BG_LOG_FILE" >&2
                return 0
            fi
        fi
        # Check if the process died
        if ! kill -0 "$bg_pid" 2>/dev/null; then
            err "server failed to start (pid $bg_pid exited)"
            err "check $BG_LOG_FILE for details"
            return 1
        fi
        sleep 0.25
    done
    echo "$PROG: started (pid $bg_pid), waiting for URL..." >&2
    echo "$PROG: check $BG_LOG_FILE or run 'labsh url' once ready" >&2
    return 0
}

cmd_stop() {
    run_helper_fast stop "$@"
    # Also clean up our pidfile.
    rm -f "$BG_PID_FILE" 2>/dev/null
}

cmd_status() {
    if ! check_lab_venv; then
        echo "servers: (none)"
        echo ""
        echo "kernels: (none)"
        echo ""
        echo "labsh helper venv not configured. Run 'labsh kernel add' or 'labsh start' first." >&2
        return 0
    fi
    "$LAB_VENV_DIR/bin/python" "$HELPER_PY" status "$@"
}

cmd_password() {
    require_uv
    mkdir -p "$JUPYTER_CONFIG_DIR"
    exec uvx --python "$LAB_PYTHON" --from jupyterlab jupyter-lab password "$@"
}

cmd_token() {
    # Print, rotate, or locate the stable Jupyter auth token.
    #   labsh token            # print token (create if missing)
    #   labsh token --rotate   # regenerate (invalidates existing sessions)
    #   labsh token --path     # print absolute path to the token file
    case "${1:-}" in
        ""|print)
            read_token
            echo ;;
        --rotate|rotate)
            rm -f "$TOKEN_FILE"
            ensure_token
            read_token
            echo
            if [ -f "$BG_PID_FILE" ]; then
                echo "$PROG: restart the server ('labsh stop && labsh start') to apply the new token." >&2
            fi ;;
        --path|path)
            echo "$TOKEN_FILE" ;;
        -h|--help|help)
            cat <<'TOKHELP'
labsh token — print, rotate, or locate the stable Jupyter auth token.

USAGE
  labsh token              Print the token (create if missing)
  labsh token --rotate     Regenerate; restart server to apply
  labsh token --path       Print absolute path to the token file

The token file lives at ./.jupyter/token (mode 0600). Any process on
this machine with read access to the file can authenticate to the
Jupyter server, e.g.:

  TOKEN=$(labsh token)
  curl -H "Authorization: token $TOKEN" http://localhost:8888/api/status

The token is passed to Jupyter via the JUPYTER_TOKEN env var, NOT the
command line, so it does not appear in `ps` output.
TOKHELP
            ;;
        *)
            die "token: unknown arg '$1' (try 'labsh token --help')" ;;
    esac
}

cmd_url() {
    # Print the access URL of the running labsh server.
    local runtime_dir="$JUPYTER_DATA_DIR/runtime"
    [ -d "$runtime_dir" ] || die "no labsh server running (no runtime dir)"
    local jf pid url token
    for jf in "$runtime_dir"/jpserver-*.json; do
        [ -e "$jf" ] || continue
        pid="$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('pid',''))" "$jf" 2>/dev/null)" || continue
        [ -n "$pid" ] || continue
        if kill -0 "$pid" 2>/dev/null; then
            url="$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('url',''))" "$jf" 2>/dev/null)" || url=""
            token="$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('token',''))" "$jf" 2>/dev/null)" || token=""
            if [ -n "$url" ]; then
                if [ -n "$token" ]; then
                    echo "${url}lab?token=${token}"
                else
                    echo "${url}lab"
                fi
                return 0
            fi
        fi
    done
    die "no running labsh server found"
}

cmd_serve() {
    require_uv
    mkdir -p "$JUPYTER_CONFIG_DIR" "$JUPYTER_DATA_DIR"

    # Warn (but don't block) if a server is already running — the user may
    # be intentionally starting a second one on a different port.
    check_existing_server && \
        echo "$PROG: starting anyway (Ctrl-C to abort)..." >&2

    parse_server_flags "$@"
    ensure_lab_venv
    ensure_jupyter_config
    JUPYTER_TOKEN="$(read_token)"
    export JUPYTER_TOKEN

    exec uvx --python "$LAB_PYTHON" --from jupyterlab \
        "${WITH_ARGS[@]}" \
        jupyter-lab \
        --port "$RESOLVED_PORT" \
        --ip "$RESOLVED_IP" \
        ${TLS_ARGS[@]+"${TLS_ARGS[@]}"} \
        ${PASSTHROUGH_ARGS[@]+"${PASSTHROUGH_ARGS[@]}"}
}

main() {
    case "${1:-}" in
        version|--version|-V)
            cat "$VERSION_FILE" 2>/dev/null || echo "unknown" ;;
        help|-h|--help)  usage ;;
        kernel)          shift; cmd_kernel   "$@" ;;
        notebook)        shift; cmd_notebook "$@" ;;
        start)           shift; cmd_start    "$@" ;;
        stop)            shift; cmd_stop     "$@" ;;
        status)          shift; cmd_status   "$@" ;;
        url)             shift; cmd_url      "$@" ;;
        password)        shift; cmd_password "$@" ;;
        token)           shift; cmd_token    "$@" ;;
        serve)           shift; cmd_serve    "$@" ;;
        "")              cmd_serve ;;
        -*)              cmd_serve "$@" ;;
        *)               die "unknown command '$1' (try '$PROG help')" ;;
    esac
}

main "$@"
